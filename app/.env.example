# ── Application ─────────────────────────────────────────────────
APP_SECRET=change-me-to-a-long-random-string

# ── Database (SQLite 单文件，无需 MySQL) ─────────────────────────
# 默认即可，数据保存在 ./data/izk.db
DATABASE_URL=file:./data/izk.db

# ── Server (production) ────────────────────────────────────────
PORT=3000
